using System;

class Program
{
    static void Main()
    {
        Car myCar = new Car("Toyota", "Corolla", 2022);
        
        myCar.DisplayInfo();
        myCar.StartEngine();
        myCar.Accelerate(40);
        myCar.Brake();
        myCar.StopEngine();
    }
}

class Car
{
    public string Make { get; set; }
    public string Model { get; set; }
    public int Year { get; set; }
    public int Speed { get; private set; }
    public bool IsEngineRunning { get; private set; }

    public Car(string make, string model, int year)
    {
        Make = make;
        Model = model;
        Year = year;
        Speed = 0;
        IsEngineRunning = false;
    }

    public void DisplayInfo()
    {
        Console.WriteLine($"Car: {Year} {Make} {Model}");
    }

    public void StartEngine()
    {
        if (!IsEngineRunning)
        {
            IsEngineRunning = true;
            Console.WriteLine("Engine started.");
        }
    }

    public void Accelerate(int amount)
    {
        if (IsEngineRunning)
        {
            Speed += amount;
            Console.WriteLine($"Accelerating. Current speed: {Speed} km/h");
        }
        else
        {
            Console.WriteLine("Cannot accelerate. Start the engine first.");
        }
    }

    public void Brake()
    {
        Speed = 0;
        Console.WriteLine("Brakes applied. Car stopped.");
    }

    public void StopEngine()
    {
        if (IsEngineRunning && Speed == 0)
        {
            IsEngineRunning = false;
            Console.WriteLine("Engine stopped.");
        }
        else if (Speed > 0)
        {
            Console.WriteLine("Cannot stop engine while driving.");
        }
    }
}
